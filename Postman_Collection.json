          "raw": "{\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"email\": \"john@example.com\",\n    \"phone\": \"0771234567\",\n    \"jobRole\": \"Technician\",\n    \"department\": \"Maintenance\",\n    \"status\": \"Active\",\n    \"provinceId\": 1,\n    \"siteId\": 1,\n    \"skillIds\": [1]\n}"
